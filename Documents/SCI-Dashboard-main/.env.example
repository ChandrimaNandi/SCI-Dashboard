# GEF API Configuration
# Get your API key from: https://www.electricitymap.org/
export GEF_API_TOKEN=your_api_key_here

# Enable/disable fetching GEF values from web API
# Set to 'true' to use real-time grid emission factor data
# Set to 'false' to use GEF values from Excel files (default)
export USE_WEB_GEF=false

# InfluxDB Configuration (optional - defaults provided in script)
# INFLUXDB_URL=http://localhost:8086
# INFLUXDB_TOKEN=demo_token_please_change
# INFLUXDB_ORG=demo_org
# INFLUXDB_BUCKET=demo_bucket
